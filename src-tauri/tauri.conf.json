{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ReadNotes",
  "mainBinaryName": "ReadNotes",
  "version": "0.1.0",
  "identifier": "top.volan.readnotes",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "摘抄库",
        "width": 1700,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "app",
      "dmg"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "publisher": "Julian F.",
    "copyright": "Licensed under the MIT License.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
